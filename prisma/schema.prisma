// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// generator client {
//   provider = "prisma-client"
//   output   = "../app/generated/prisma"
// }

// datasource db {
//   provider = "postgresql"
// }

// Tells Prisma which database engine to use and where to find it
datasource db {
  provider = "postgresql"
}

// Generates the type-safe Prisma client you'll use in your code
generator client {
  provider = "prisma-client-js"
}

// ---- ENUMS ----
// Enums restrict a field to a fixed set of values, preventing bad data

enum Role {
  USER
  AGENT
  ADMIN
}

enum ListingStatus {
  PENDING   // waiting for admin approval
  ACTIVE    // live and visible to the public
  SOLD
  RENTED
}

enum ListingType {
  RENT
  SALE
}

enum PropertyCategory {
  HOUSE
  APARTMENT
  SELF_CONTAINED
  COMPOUND_HOUSE
  LAND
  TOWNHOUSE
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ---- MODELS ----

// Core user model — works with NextAuth, stores role for access control
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null if user signed up via Google/GitHub
  role          Role      @default(USER)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts         Account[]
  sessions         Session[]
  listings         Listing[]
  savedProperties  SavedProperty[]
  sentMessages     Message[]        @relation("SentMessages")
  receivedMessages Message[]        @relation("ReceivedMessages")
  agentApplication AgentApplication?
}

// Required by NextAuth to store OAuth account connections (Google, GitHub)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Required by NextAuth to manage active user sessions
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Required by NextAuth for email verification tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Core listing model — the heart of the platform
model Listing {
  id           String           @id @default(cuid())
  title        String
  description  String           @db.Text
  price        Float
  type         ListingType
  category     PropertyCategory
  status       ListingStatus    @default(PENDING)
  images       String[]         // array of Cloudinary URLs
  bedrooms     Int?
  bathrooms    Int?
  area         Float?           // in square meters
  address      String
  city         String
  region       String
  featured     Boolean          @default(false) // for homepage featured section
  amenities    String[]         // e.g. ["parking", "generator", "borehole"]
  agentId      String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Relations
  agent        User            @relation(fields: [agentId], references: [id])
  savedBy      SavedProperty[]
  messages     Message[]
}

// Join table — lets users bookmark/save listings they're interested in
model SavedProperty {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId]) // prevents duplicate saves
}

// Messaging between buyers and agents, scoped to a specific listing
model Message {
  id         String   @id @default(cuid())
  body       String   @db.Text
  read       Boolean  @default(false)
  listingId  String
  senderId   String
  receiverId String
  createdAt  DateTime @default(now())

  listing  Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sender   User    @relation("SentMessages", fields: [senderId], references: [id])
  receiver User    @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

// Stores agent applications submitted by regular users
model AgentApplication {
  id        String            @id @default(cuid())
  userId    String            @unique // one application per user
  phone     String
  bio       String            @db.Text
  idNumber  String            // Ghana Card or passport number
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}